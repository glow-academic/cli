{{ $project := .Env.COMPOSE_PROJECT_NAME }}
upstream blue_server {
    least_conn;
    {{ range $c := $ }}
      {{ if and $c.State.Running (eq (index $c.Labels "com.docker.compose.service") "server-blue") (eq (index $c.Labels "com.docker.compose.project") $project) }}
        server {{ $c.Name }}:8000 max_fails=3 fail_timeout=30s;
      {{ end }}
    {{ end }}
    server 127.0.0.1:1 down;
}

upstream green_server {
    least_conn;
    {{ range $c := $ }}
      {{ if and $c.State.Running (eq (index $c.Labels "com.docker.compose.service") "server-green") (eq (index $c.Labels "com.docker.compose.project") $project) }}
        server {{ $c.Name }}:8000 max_fails=3 fail_timeout=30s;
      {{ end }}
    {{ end }}
    server 127.0.0.1:1 down;
}

