Output demo-output/start-overview.mp4

Set Shell "bash"
Set Width 1200
Set Height 720
Set FontSize 18
Set Padding 16
Set TypingSpeed 35ms

Type "glow --help"
Enter
Sleep 2s

Type "clear"
Enter
Sleep 500ms

Type "glow init --help"
Enter
Sleep 2s

Type "clear"
Enter
Sleep 500ms

Type "glow status --help"
Enter
Sleep 2s

Type "clear"
Enter
Sleep 500ms

Type "glow deploy --help"
Enter
Sleep 2s
