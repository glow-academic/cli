Output demo-output/backup-restore.mp4

Set Shell "bash"
Set Width 1600
Set Height 900
Set FontSize 24
Set Padding 20
Set TypingSpeed 35ms

Type "glow redeploy --help"
Enter
Sleep 2s

Type "clear"
Enter
Sleep 500ms

Type "glow backup restore --help"
Enter
Sleep 2s

Type "clear"
Enter
Sleep 500ms

Type "glow backup list --help"
Enter
Sleep 2s
