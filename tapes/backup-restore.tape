Output demo-output/backup-restore.mp4

Set Shell "bash"
Set Width 1200
Set Height 720
Set FontSize 18
Set Padding 16
Set TypingSpeed 35ms

Type "glow redeploy --help"
Enter
Sleep 2s

Type "clear"
Enter
Sleep 500ms

Type "glow backup restore --help"
Enter
Sleep 2s

Type "clear"
Enter
Sleep 500ms

Type "glow backup list --help"
Enter
Sleep 2s
